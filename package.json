{
  "name": "great-work",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "build:views": "node scripts/build-views.mjs",
    "lint:wiki": "node scripts/wiki-lint.mjs",
    "dev": "vite",
    "build": "node scripts/build-views.mjs && node scripts/build-locations.mjs && tsc -b && vite build && cp -r wiki/pages wiki/views wiki/meta dist/",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node --test scripts/*.test.mjs",
    "urls:plaintext": "node scripts/plaintext-urls.mjs",
    "startup-state:check": "node scripts/check-startup-state-resources.mjs",
    "startup-state:sync": "node scripts/sync-startup-state-from-api.mjs",
    "startup-state:check:strict": "node scripts/check-startup-state-resources.mjs --strict"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.24.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
